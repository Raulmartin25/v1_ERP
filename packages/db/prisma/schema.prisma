// Restaurant ERP — Prisma schema
// Money fields are integers in minor units (cents). See packages/shared/money.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MENU & RECIPE MANAGEMENT
// ============================================================

model Ingredient {
  id          String       @id @default(cuid())
  name        String       @unique
  unit        String // g, ml, unit
  // Cost in cents per `unit`, kept with sub-cent precision because bulk
  // ingredients (e.g. flour, potato) cost a fraction of a cent per gram.
  // Recipe totals are rounded to whole cents only at the end.
  costPerUnit Decimal      @db.Decimal(12, 4)
  stockQty    Decimal      @default(0) @db.Decimal(12, 3)
  recipeLines RecipeLine[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MenuItem {
  id            String              @id @default(cuid())
  name          String
  category      String
  price         Int // sale price, cents
  isActive      Boolean             @default(true)
  recipe        Recipe?
  orderLines    OrderLine[]
  modifierLinks MenuItemModifier[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Recipe {
  id         String       @id @default(cuid())
  name       String
  yieldQty   Decimal      @default(1) @db.Decimal(12, 3)
  menuItem   MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String       @unique
  lines      RecipeLine[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model RecipeLine {
  id           String     @id @default(cuid())
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String
  quantity     Decimal    @db.Decimal(12, 3) // in the ingredient's unit

  @@unique([recipeId, ingredientId])
}

model ModifierGroup {
  id        String             @id @default(cuid())
  name      String // e.g. "Extras", "Cooking preference"
  modifiers Modifier[]
  menuLinks MenuItemModifier[]
}

model Modifier {
  id         String        @id @default(cuid())
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId    String
  name       String // e.g. "Extra cheese"
  priceDelta Int           @default(0) // cents, may be negative

  orderLineMods OrderLineModifier[]
}

// Join table: which modifier groups apply to which menu items
model MenuItemModifier {
  menuItem   MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId    String

  @@id([menuItemId, groupId])
}

// ============================================================
// POS / ORDERS
// ============================================================

model RestaurantTable {
  id     String  @id @default(cuid())
  number Int     @unique
  area   String?
  seats  Int     @default(4)
  orders Order[]
}

model Order {
  id        String           @id @default(cuid())
  number    Int              @unique @default(autoincrement())
  channel   String // OrderChannel
  status    String           @default("OPEN") // OrderStatus
  table     RestaurantTable? @relation(fields: [tableId], references: [id])
  tableId   String?
  lines     OrderLine[]
  payments  Payment[]
  subtotal  Int              @default(0) // cents
  taxTotal  Int              @default(0) // cents
  total     Int              @default(0) // cents
  journalEntry JournalEntry?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model OrderLine {
  id         String              @id @default(cuid())
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id])
  menuItemId String
  nameSnapshot String // name captured at time of sale
  qty        Int
  unitPrice  Int // cents, captured at sale time
  lineTotal  Int // cents, (unitPrice + mods) * qty
  modifiers  OrderLineModifier[]
}

model OrderLineModifier {
  id           String    @id @default(cuid())
  orderLine    OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  orderLineId  String
  modifier     Modifier  @relation(fields: [modifierId], references: [id])
  modifierId   String
  nameSnapshot String
  priceDelta   Int // cents, captured at sale time
}

model Payment {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  method    String // PaymentMethod
  amount    Int // cents
  createdAt DateTime @default(now())
}

// ============================================================
// FINANCE & ACCOUNTING (double-entry ledger)
// ============================================================

model Account {
  id        String        @id @default(cuid())
  code      String        @unique // e.g. "1000"
  name      String // e.g. "Cash"
  type      String // AccountType
  lines     JournalLine[]
  createdAt DateTime      @default(now())
}

model JournalEntry {
  id          String        @id @default(cuid())
  date        DateTime      @default(now())
  description String
  // Optional link back to the source document (e.g. an order)
  order       Order?        @relation(fields: [orderId], references: [id])
  orderId     String?       @unique
  lines       JournalLine[]
  createdAt   DateTime      @default(now())
}

model JournalLine {
  id        String       @id @default(cuid())
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId   String
  account   Account      @relation(fields: [accountId], references: [id])
  accountId String
  debit     Int          @default(0) // cents
  credit    Int          @default(0) // cents

  @@index([accountId])
}
